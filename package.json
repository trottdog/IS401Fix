{
  "name": "byuclubs-web",
  "main": "src/main.tsx",
  "version": "1.0.0",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "postinstall": "node -e \"const cp=require('node:child_process');const result=cp.spawnSync('patch-package',{stdio:'inherit',shell:true});if(result.error||result.status!==0){console.log('patch-package not available in this install; continuing without applying patches.');}\"",
    "server:dev": "npm run dev",
    "dev": "npm run web:build && node --import tsx server/index.ts",
    "web:dev": "vite",
    "web:build": "vite build",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=cjs --outdir=server_dist",
    "server:prod": "node server_dist/index.js",
    "build": "npm run web:build && npm run server:build",
    "start": "npm run dev",
    "db:migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "db:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "db:status": "knex --knexfile knexfile.cjs migrate:status",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.6",
    "@tanstack/react-query": "^5.83.0",
    "@types/express-session": "^1.18.2",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "esbuild": "^0.25.9",
    "express": "^5.0.1",
    "express-session": "^1.19.0",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-icons": "^5.5.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.20.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.5.1",
    "react-router-dom": "^7.8.2",
    "patch-package": "^8.0.0",
    "tsx": "^4.20.6",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.2",
    "@babel/core": "^7.25.2",
    "@types/express": "^5.0.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "eslint": "^9.31.0",
    "typescript": "~5.9.2",
    "vite": "^7.1.3"
  },
  "private": true
}
