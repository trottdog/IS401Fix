{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "postinstall": "node -e \"const cp=require('node:child_process');const result=cp.spawnSync('patch-package',{stdio:'inherit',shell:true});if(result.error||result.status!==0){console.log('patch-package not available in this install; continuing without applying patches.');}\"",
    "server:dev": "npm run dev",
    "dev": "npm run web:build && node --import tsx server/index.ts",
    "web:dev": "npm run dev",
    "web:build": "npx expo export --platform web --output-dir static-build",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=cjs --outdir=server_dist",
    "server:prod": "node server_dist/index.js",
    "build": "npm run web:build && npm run server:build",
    "start": "npm run dev",
    "db:migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "db:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "db:status": "knex --knexfile knexfile.cjs migrate:status",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@tanstack/react-query": "^5.83.0",
    "@types/express-session": "^1.18.2",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-crypto": "^15.0.8",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "~0.1.4",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "esbuild": "^0.25.9",
    "express": "^5.0.1",
    "express-session": "^1.19.0",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.20.6",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.5.1",
    "patch-package": "^8.0.0",
    "tsx": "^4.20.6",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/react": "~19.1.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
